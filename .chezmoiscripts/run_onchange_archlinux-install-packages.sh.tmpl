{{ if eq .osid "linux-arch" -}}
#!/bin/bash

if ! command -v paru >/dev/null 2>&1; then
    sudo pacman -S --needed base-devel
    git clone https://aur.archlinux.org/paru.git
    pushd paru
    makepkg -si
    popd
    rm -rf paru
fi

paru -S --needed  {{ .packages.arch.core | join " " }}

{{ if not .headless -}}
paru -S --needed  {{ .packages.arch.desktop | join " " }}
{{ end -}}
{{ if .wsl -}}
paru -S --needed {{ .packages.arch.wsl | join " " }}
{{ end -}}
{{ end -}}
