{{- $validOs := list "linux-arch" "linux-cachyos" -}}
{{ if has .osid $validOs -}}
#!/bin/bash

CORE_PACKAGES=(
    btop
    eza
    docker
    docker-buildx
    docker-compose
    fd
    fish
    fzf
    lazygit
    mise
    neovim-git
    openai-codex-bin
    opencode-bin
    pacman-contrib
    ripgrep
    starship
    usage
    wget
    xdg-utils
    yazi
    zellij
    zoxide
)

echo "Installing core packages..."
paru -S --needed ${CORE_PACKAGES[@]}

{{ if eq .hosttype "laptop" -}}
NIRI_PACKAGES=(
    adw-gtk-theme
    cliphist
    evolution-data-server
    foot
    fprintd
    fuzzel
    mpv
    nautilus
    niri
    nwg-look
    python3
    vulkan-icd-loader
    lib32-vulkan-icd-loader
    vulkan-radeon
    lib32-vulkan-radeon
    wlsunset
    xclip
    xdg-desktop-portal
    xdg-desktop-portal-gnome
    xdg-desktop-portal-gtk
    xwayland-satellite
)

echo "Installing niri-related packages..."
paru -S --needed ${NIRI_PACKAGES[@]}
{{ end -}}

GUI_PACKAGES=(
    vscodium
)

FONT_PACKAGES=(
    otf-comicshanns-nerd
    noto-fonts
    noto-fonts-cjk
    noto-fonts-emoji
    ttf-dejavu
    ttf-jetbrains-mono-nerd
)

echo "Installing gui-related packages..."
paru -S --needed ${GUI_PACKAGES[@]}

echo "Installing font packages..."
paru -S --needed ${FONT_PACKAGES[@]}
{{ end -}}
