{{ if eq .osid "linux-arch" -}}
#!/bin/bash

CORE_PACKAGES=(
    btop
    eza
    {{- if not .wsl }}
    docker
    docker-buildx
    docker-compose
    {{- end }}
    fd
    fish
    fzf
    lazygit
    mise
    neovim-git
    openai-codex-bin
    opencode-bin
    pacman-contrib
    ripgrep
    starship
    usage
    wget
    xdg-utils
    yazi
    zellij
    zoxide
)

echo "Installing core packages..."
paru -S --needed ${CORE_PACKAGES[@]}

{{ if not .headless -}}
DESKTOP_PACKAGES=(
    adw-gtk-theme
    cliphist
    cursor-bin
    evolution-data-server
    flatpak
    foot
    fprintd
    fuzzel
    mpv
    nautilus
    niri
    nwg-look
    python3
    t3code-bin
    vscodium
    vulkan-icd-loader
    lib32-vulkan-icd-loader
    vulkan-radeon
    lib32-vulkan-radeon
    wlsunset
    xclip
    xdg-desktop-portal
    xdg-desktop-portal-gnome
    xdg-desktop-portal-gtk
    xwayland-satellite
)

FONT_PACKAGES=(
    otf-comicshanns-nerd
    noto-fonts
    noto-fonts-cjk
    noto-fonts-emoji
    ttf-dejavu
    ttf-jetbrains-mono-nerd
)

echo "Installing desktop-related packages..."
paru -S --needed ${DESKTOP_PACKAGES[@]}

echo "Installing font packages..."
paru -S --needed ${FONT_PACKAGES[@]}
{{ end -}}
{{ if .wsl -}}
WSL_PACKAGES=(
    wsl2-ssh-agent
)

echo "Installing WSL-related packages..."
paru -S --needed ${WSL_PACKAGES[@]}
{{ end -}}
{{ end -}}
