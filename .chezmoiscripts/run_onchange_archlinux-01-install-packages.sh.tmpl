{{- $validOs := list "linux-arch" "linux-cachyos" -}}
{{ if has .osid $validOs -}}
#!/bin/bash

echo "Updating Arch repositories"
sudo pacman -Syu

CORE_PACKAGES=(
    btop
    eza
    fd
    fish
    fzf
    lazygit
    less
    mise
    neovim-git
    opencode-bin
    pacman-contrib
    ripgrep
    starship
    usage
    wget
    xdg-utils
    yazi
    zellij
    zoxide
)

echo "Installing core packages..."
paru -S --needed ${CORE_PACKAGES[@]}

{{ if eq .osid "linux-arch" -}}
GPU_PACKAGES=(
    vulkan-icd-loader
    lib32-vulkan-icd-loader
    vulkan-radeon
    lib32-vulkan-radeon
)

echo "Installing gpu-related packages..."
paru -S --needed ${GPU_PACKAGES[@]}
{{ end -}}

GUI_PACKAGES=(
    bitwarden-bin
    vscodium
    zed
)

FONT_PACKAGES=(
    otf-comicshanns-nerd
    noto-fonts
    noto-fonts-cjk
    noto-fonts-emoji
    ttf-dejavu
    ttf-jetbrains-mono-nerd
)

echo "Installing gui-related packages..."
paru -S --needed ${GUI_PACKAGES[@]}

echo "Installing font packages..."
paru -S --needed ${FONT_PACKAGES[@]}
{{ end -}}
