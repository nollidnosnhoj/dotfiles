{{ if eq .hosttype "work" -}}
#!/bin/bash

BREW_TAPS=(
    FelixKratz/formulae
)

brew tap ${BREW_TAPS[@]}

BREW_CASKS=(
    aerospace
    bitwarden
    dbeaver-community
    font-comic-shanns-mono-nerd-font
    font-hack-nerd-font
    ghostty
    gitkraken
    headlamp
    helium-browser
    microsoft-teams
    postman
    # raycast # using raycast beta version
    visual-studio-code
)

brew install --cask ${BREW_CASKS[@]}

BREW_FORMULAES=(
    azure-cli
    chezmoi
    docker
    docker-completion
    eza
    fish
    fzf
    gh
    helm
    jq
    kubernetes-cli
    kustomize
    lazygit
    mise
    neovim
    ripgrep
    sketchybar
    starship
    tree-sitter
    usage
    zoxide
)

brew install ${BREW_FORMULAES[@]}
