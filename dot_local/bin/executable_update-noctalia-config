#!/bin/bash

if ! command -v chezmoi &> /dev/null; then
    echo "chezmoi not found"
    exit 1
fi

chezmoi add \
    ~/.config/btop/ \
    ~/.config/foot/ \
    ~/.config/kitty/ \
    ~/.config/niri/ \
    ~/.config/yazi/ \
    ~/.config/starship.toml \
    ~/.pi/agent/settings.json \
    ~/.pi/agent/themes/noctalia.json
