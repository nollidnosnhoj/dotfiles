#!/usr/bin/env bash
{{- $hasParu := lookPath "paru" -}}
{{- $hasBrew := lookPath "brew" -}}
{{- $hasMise := lookPath "mise" -}}
{{- $hasShelly := lookPath "shelly" -}}

{{ if $hasBrew }}
echo "Updating Homebrew packages..."
brew update
brew upgrade
{{ end }}
{{ if $hasShelly }}
echo "Updating system packages with shelly..."
shelly
{{ else if $hasParu }}
echo "Updating Arch Linux packages..."
sudo pacman -Syu
echo "Update AUR packages"
paru -Sua
{{ end }}
{{ if $hasMise }}
echo "Updating mise..."
mise self-update
echo "Updating mise tools..."
mise upgrade
{{ end }}
