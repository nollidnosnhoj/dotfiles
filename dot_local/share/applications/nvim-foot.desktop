[Desktop Entry]
Type=Application
Name=Neovim (foot)
GenericName=Text Editor
Comment=Edit text files with Neovim in the foot terminal
Exec=foot -e nvim %F
Terminal=false
Icon=nvim
Categories=Utility;TextEditor;Development;
MimeType=text/plain;text/x-script;text/x-shellscript;text/x-python;text/markdown;application/json;application/x-yaml;text/x-c;text/x-c++src;text/x-java;text/x-lua;
StartupNotify=true
