            - fzf
            - git
            - github-cli
            - jq
            - lazygit
            - less
            - neovim-git
            - opencode-bin
            - pacman-contrib
            - podman
            - podman-docker
            - ripgrep
            - starship
            - usage
            - wget
            - xdg-utils
            - yazi
            - zellij
            - zoxide
            gpu:
            - vulkan-icd-loader
            - lib32-vulkan-icd-loader
            - vulkan-radeon
            - lib32-vulkan-radeon
            gui:
            - bitwarden-bin
            - vscodium
            - zed
            fonts:
            - otf-comicshanns-nerd
            - noto-fonts
            - noto-fonts-cjk
            - noto-fonts-emoji
            - ttf-dejavu
            - ttf-jetbrains-mono-nerd
            niri:
            - adw-gtk-theme
