{{- $choices := list "desktop" "laptop" -}}
{{- $hosttype := "" -}}
{{- $osid := .chezmoi.os -}}
{{- $email := "me@nollidnosnhoj.com" -}}
{{- $name := "Dillon Johnson" -}}
{{- $niri := false -}}
{{- $wsl := false -}}

{{- if (and (eq .chezmoi.os "linux") (hasKey .chezmoi.osRelease "id")) -}}
{{-     $osid = printf "%s-%s" .chezmoi.os .chezmoi.osRelease.id -}}
{{- end -}}

{{- if eq .chezmoi.os "linux" -}}
{{-     $wsl = (.chezmoi.kernel.osrelease | lower | contains "microsoft") -}}
{{-     if $wsl -}}
{{-         $hosttype = "wsl" -}}
{{-     end -}}
{{- end -}}

{{- if eq $osid "darwin" -}}
{{-     $hosttype = "work" -}}
{{-     $email = "rjohnson@gericall.nl" -}}
{{-     $name = "Randall Dillon Johnson" -}}
{{- end -}}

{{- if (and (eq .chezmoi.os "linux") (not $wsl)) -}}
{{-     $niri = promptBool "Install niri?" -}}
{{- end -}}

{{- if eq $hosttype "" -}}
{{-     if and (hasKey . "hosttype") (has .hosttype $choices) -}}
{{-         $hosttype = .hosttype -}}
{{-     else -}}
{{-         $hosttype = promptChoice "What type of host are you on" $choices -}}
{{-     end -}}
{{- end -}}

encryption: age
age:
    identity: "~/.config/chezmoi/key.txt"
    recipient: age1w86ktsveqqux2etahn80098wrcn98f03xjgykghfqz6vxk85n5ysaguj79

hooks:
    read-source-state:
        pre:
            command: ".local/share/chezmoi/.decrypt-private-key.sh"
