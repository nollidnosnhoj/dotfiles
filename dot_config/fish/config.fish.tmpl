{{ if (and (eq .chezmoi.os "linux") (eq .chezmoi.osRelease.id "cachyos")) }}
if test -f /usr/share/cachyos-fish-config/cachyos-config.fish
    source /usr/share/cachyos-fish-config/cachyos-config.fish
end
{{ end }}

{{- /* These are things that are in the cachyos-config.fish that I want used in other non-cachyos machines */ -}}
{{ if (or (ne .chezmoi.os "linux") (ne .chezmoi.osRelease.id "cachyos")) }}
# Apply .profile: use this to put fish compatible .profile stuff in
if test -f ~/.fish_profile
    source ~/.fish_profile
end

# Add ~/.local/bin to PATH
if test -d ~/.local/bin
    if not contains -- ~/.local/bin $PATH
        set -p PATH ~/.local/bin
    end
end
{{ end }}

function fish_greeting
    # show nothing
end
